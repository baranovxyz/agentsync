{
  "name": "agentsync",
  "version": "1.0.0-beta.0",
  "description": "The missing infrastructure layer for AI coding agent configuration management",
  "type": "module",
  "bin": {
    "agentsync": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "templates",
    "src/bundled-skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc && vite build && node scripts/add-shebang.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:shell": "vitest run tests/e2e/version-smoke.test.ts",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "security:audit": "pnpm audit --audit-level moderate",
    "prepublishOnly": "pnpm test && pnpm build",
    "cz": "cz",
    "commitlint": "commitlint --from=origin/main --to=HEAD",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agents",
    "agents.md",
    "cursor",
    "claude",
    "claude-code",
    "opencode",
    "github-copilot",
    "config",
    "configuration",
    "sync",
    "synchronization",
    "ai-tools",
    "developer-tools",
    "cli",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baranovxyz/agentsync.git"
  },
  "homepage": "https://github.com/baranovxyz/agentsync#readme",
  "bugs": {
    "url": "https://github.com/baranovxyz/agentsync/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "baranovxyz",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@inquirer/prompts": "7.10.1",
    "commander": "14.0.3",
    "es-main": "1.4.0",
    "execa": "9.6.1",
    "fast-glob": "3.3.3",
    "js-yaml": "4.1.1",
    "micromatch": "4.0.8",
    "ora": "9.4.0",
    "picocolors": "1.1.1",
    "smol-toml": "1.6.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@inquirer/testing": "2.1.51",
    "@types/js-yaml": "4.0.9",
    "@types/micromatch": "4.0.10",
    "@types/node": "24.8.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "3.2.4",
    "@commitlint/cli": "19.6.0",
    "@commitlint/config-conventional": "19.6.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7"
  },
  "packageManager": "pnpm@10.22.0",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "picomatch@^2.3.1": "2.3.2",
      "picomatch@^4.0.3": "4.0.4",
      "postcss@^8.5.6": "8.5.12",
      "brace-expansion@^2.0.0": "2.0.3",
      "brace-expansion@^5.0.0": "5.0.5",
      "lodash": "4.18.1",
      "tmp": "0.2.5"
    }
  }
}
