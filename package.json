{
  "name": "agentsync",
  "version": "0.1.0",
  "description": "The missing infrastructure layer for AI coding agent configuration management",
  "type": "module",
  "bin": {
    "agentsync": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "dev:vite": "vite-node --watch src/cli.ts",
    "build": "tsc && vite build",
    "postbuild": "node scripts/add-shebang.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "lint:fix": "prettier --write src tests",
    "security:audit": "npm audit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "ai",
    "agents",
    "cursor",
    "claude",
    "cline",
    "windsurf",
    "copilot",
    "config",
    "sync",
    "agents.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/baranovxyz/agentsync"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "gray-matter": "^4.0.3",
    "ini": "^5.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^9.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.8.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^3.2.4",
    "chokidar": "^4.0.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
