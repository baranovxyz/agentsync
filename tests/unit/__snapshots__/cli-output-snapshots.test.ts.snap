exports[`CLI Output Snapshots > MCP Commands Help > mcp sync --help output matches snapshot 1`] = `
"Usage: agentsync mcp sync [options]

Sync selected MCPs to AI coding tools

Options:
  --tool <name>  Sync only to specific tool (cursor, claude)
  --dry-run      Preview changes without applying them
  -h, --help     display help for command"
`;

exports[`CLI Output Snapshots > Version and Help > --help output matches snapshot 1`] = `
"Usage: agentsync [options] [command]

Sync your AGENTS.md to all your AI coding tools - Cursor, Claude Code, Cline,
Windsurf, GitHub Copilot

Options:
  -V, --version   output the version number
  -h, --help      display help for command

Commands:
  init [options]  Initialize AgentSync with interactive setup wizard
  mcp             Manage MCP (Model Context Protocol) servers
  sync [options]  Sync libraries, rules, commands, and MCPs to AI tools
  library         Manage GitHub library sources
  help [command]  display help for command

  ╔═══════════════════════════════════════╗
  ║     AgentSync v0.2.0-alpha.9              ║
  ║  The missing infrastructure layer     ║
  ║  for AI agent configuration sync      ║
  ╚═══════════════════════════════════════╝
  

Examples:
  $ agentsync init                      # Interactive setup wizard
  $ agentsync sync                      # Sync libraries, rules, commands, MCPs
  $ agentsync sync --update             # Update GitHub caches and sync
  $ agentsync sync --dry-run            # Preview sync changes
  $ agentsync library list              # List configured libraries
  $ agentsync library cache-clear       # Clear library caches
  $ agentsync mcp list                  # List available MCPs
  $ agentsync mcp add github            # Add MCP server

Documentation:
  https://github.com/baranovxyz/agentsync"
`;
