{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "{GITHUB_TOKEN}"
      }
    },
    "postgres": {
      "command": "docker",
      "args": ["exec", "postgres-mcp"],
      "env": {
        "POSTGRES_URL": "{POSTGRES_URL}"
      }
    }
  },
  "mcpEnabled": ["github", "postgres"]
}
