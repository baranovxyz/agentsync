#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Prevent pushing to main from local clone (advisory; server-side protection is authoritative)
branch_name="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
if [ "$branch_name" = "main" ]; then
  echo "❌ Direct pushes to main are not allowed. Please open a PR."
  exit 1
fi

