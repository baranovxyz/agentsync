#!/bin/sh

# Run Biome format and check on staged files only
if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required for the Biome pre-commit hook."
  exit 1
fi

PATTERN='\.(cjs|mjs|js|jsx|ts|tsx|json|jsonc)$'

# Exit early if there are no matching staged files
FILES_COUNT=$(git diff --cached --name-only --diff-filter=ACMR | grep -E "$PATTERN" | wc -l | tr -d '[:space:]')
if [ "$FILES_COUNT" = "0" ]; then
  exit 0
fi

echo "→ Biome: formatting staged files"
git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -z -E "$PATTERN" \
  | xargs -0 pnpm exec biome format --write

# Re-stage files after formatting
git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -z -E "$PATTERN" \
  | xargs -0 git add

echo "→ Biome: auto-fixing lint issues"
git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -z -E "$PATTERN" \
  | xargs -0 pnpm exec biome check --write --no-errors-on-unmatched

# Re-stage files after lint fixes
git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -z -E "$PATTERN" \
  | xargs -0 git add

echo "→ Biome: final check"
git diff --cached --name-only --diff-filter=ACMR -z \
  | grep -z -E "$PATTERN" \
  | xargs -0 pnpm exec biome check --no-errors-on-unmatched
